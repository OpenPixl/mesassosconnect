{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "vendor/doctrine/dbal": "^3",
        "vendor/doctrine/doctrine-bundle": "^2.12",
        "vendor/doctrine/doctrine-migrations-bundle": "^3.3",
        "vendor/doctrine/orm": "^3.2",
        "vendor/phpdocumentor/reflection-docblock": "^5.4",
        "vendor/phpstan/phpdoc-parser": "^1.29",
        "vendor/symfony/asset": "7.1.*",
        "vendor/symfony/asset-mapper": "7.1.*",
        "vendor/symfony/console": "7.1.*",
        "vendor/symfony/doctrine-messenger": "7.1.*",
        "vendor/symfony/dotenv": "7.1.*",
        "vendor/symfony/expression-language": "7.1.*",
        "vendor/symfony/flex": "^2",
        "vendor/symfony/form": "7.1.*",
        "vendor/symfony/framework-bundle": "7.1.*",
        "vendor/symfony/http-client": "7.1.*",
        "vendor/symfony/intl": "7.1.*",
        "vendor/symfony/mailer": "7.1.*",
        "vendor/symfony/mime": "7.1.*",
        "vendor/symfony/monolog-bundle": "^3.0",
        "vendor/symfony/notifier": "7.1.*",
        "vendor/symfony/process": "7.1.*",
        "vendor/symfony/property-access": "7.1.*",
        "vendor/symfony/property-info": "7.1.*",
        "vendor/symfony/runtime": "7.1.*",
        "vendor/symfony/security-bundle": "7.1.*",
        "vendor/symfony/serializer": "7.1.*",
        "vendor/symfony/stimulus-bundle": "^2.18",
        "vendor/symfony/string": "7.1.*",
        "vendor/symfony/translation": "7.1.*",
        "vendor/symfony/twig-bundle": "7.1.*",
        "vendor/symfony/ux-turbo": "^2.18",
        "vendor/symfony/validator": "7.1.*",
        "vendor/symfony/web-link": "7.1.*",
        "vendor/symfony/yaml": "7.1.*",
        "vendor/symfonycasts/verify-email-bundle": "^1.17",
        "vendor/twig/extra-bundle": "^2.12|^3.0",
        "vendor/twig/twig": "^2.12|^3.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.1.*"
        }
    },
    "require-dev": {
        "vendor/phpunit/phpunit": "^9.5",
        "vendor/symfony/browser-kit": "7.1.*",
        "vendor/symfony/css-selector": "7.1.*",
        "vendor/symfony/debug-bundle": "7.1.*",
        "vendor/symfony/maker-bundle": "^1.0",
        "vendor/symfony/phpunit-bridge": "^7.1",
        "vendor/symfony/stopwatch": "7.1.*",
        "vendor/symfony/web-profiler-bundle": "7.1.*"
    }
}
